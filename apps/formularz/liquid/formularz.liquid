<section class="lumlum-orderfill" data-lumlum-orderfill>
  <div class="lumlum-orderfill__wrap">
    <!-- Alerts -->
    <div class="lumlum-orderfill__alerts" aria-live="polite" aria-atomic="true"></div>

    <!-- Layout -->
    <div class="lumlum-orderfill__container">
      <div class="lumlum-orderfill__grid">

        <!-- LEFT: Form -->
        <div class="lumlum-orderfill__col lumlum-orderfill__col--left">

          <!-- Mobile: summary accordion (collapsed by default) -->
          <div class="lumlum-orderfill__mobile-summary" data-mobile-summary>
            <button
              class="lumlum-orderfill__accordion-btn"
              type="button"
              aria-expanded="false"
              aria-controls="lumlum-orderfill-summary-panel"
            >
              <div class="lumlum-orderfill__accordion-title">Podsumowanie zamówienia</div>

              <div class="lumlum-orderfill__accordion-right">
                <div class="lumlum-orderfill__accordion-total" data-total-inline>—</div>
                <span class="lumlum-orderfill__chev" aria-hidden="true"></span>
              </div>
            </button>

            <div class="lumlum-orderfill__accordion-panel is-hidden" id="lumlum-orderfill-summary-panel">
              <div class="lumlum-orderfill__summary-card lumlum-orderfill__summary-card--mobile" data-summary-card-mobile></div>
            </div>
          </div>

          <div class="lumlum-orderfill__form-card is-hidden" data-form-card>
            <div class="lumlum-orderfill__section-head">
              <div class="lumlum-title-sub" role="heading" aria-level="2">Uzupełnij dane do zamówienia</div>
              <div class="lumlum-orderfill__hint" data-order-id-line>—</div>
            </div>

            <form class="lumlum-orderfill__form" novalidate data-form>

              <!-- Dane klienta -->
              <div class="lumlum-orderfill__block">
                <div class="lumlum-orderfill__block-title" role="heading" aria-level="3">Dane klienta</div>

                <div class="lumlum-orderfill__row lumlum-orderfill__row--2">
                  <div class="lumlum-orderfill__field">
                    <label class="lumlum-orderfill__label" for="lumlum-first-name">Imię <span class="lumlum-orderfill__req" aria-hidden="true">*</span></label>
                    <input class="lumlum-orderfill__input" id="lumlum-first-name" name="first_name" autocomplete="given-name" />
                    <div class="lumlum-orderfill__field-error" data-err-for="first_name"></div>
                  </div>
                  <div class="lumlum-orderfill__field">
                    <label class="lumlum-orderfill__label" for="lumlum-last-name">Nazwisko <span class="lumlum-orderfill__req" aria-hidden="true">*</span></label>
                    <input class="lumlum-orderfill__input" id="lumlum-last-name" name="last_name" autocomplete="family-name" />
                    <div class="lumlum-orderfill__field-error" data-err-for="last_name"></div>
                  </div>
                </div>

<div class="lumlum-orderfill__row lumlum-orderfill__row--2">
