    if (!els.form) return;
    var fields = els.form.querySelectorAll('.lumlum-orderfill__field');
    for (var i=0;i<fields.length;i++) fields[i].classList.remove('is-invalid');

    var errs = els.form.querySelectorAll('.lumlum-orderfill__field-error');
    for (var j=0;j<errs.length;j++){
      errs[j].classList.remove('is-visible');
      errs[j].textContent = '';
    }
  }

  function setFieldError(name, msg){
    if (!els.form) return;
    var input = els.form.querySelector('[name="'+name+'"]');
    var field = input ? input.closest('.lumlum-orderfill__field') : null;
    if (field) field.classList.add('is-invalid');

    var err = els.form.querySelector('[data-err-for="'+name+'"]');
    if (err){
      err.textContent = msg || 'To pole jest wymagane.';
      err.classList.add('is-visible');
    }
  }

  function scrollToFirstInvalid(){
    if (!els.form) return;
    var first = els.form.querySelector('.lumlum-orderfill__field.is-invalid');
    if (!first) return;
    first.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }

  /* =========================================================
     Inject note under "Dane klienta"
     ========================================================= */
  function injectRequiredNote(){
    var blocks = els.form ? els.form.querySelectorAll('.lumlum-orderfill__block') : null;
    if (!blocks || !blocks.length) return;

    var clientBlock = blocks[0];
    if (!clientBlock) return;

    if (clientBlock.querySelector('[data-required-note]')) return;

    var note = document.createElement('div');
    note.className = 'lumlum-orderfill__micro';
    note.setAttribute('data-required-note','1');
    note.textContent = '* Oznacza obowiązkowe dane';

    var title = clientBlock.querySelector('.lumlum-orderfill__block-title');
    if (title && title.nextSibling){
      title.parentNode.insertBefore(note, title.nextSibling);
    } else {
      clientBlock.appendChild(note);
    }
