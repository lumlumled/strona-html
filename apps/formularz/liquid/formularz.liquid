      margin-top: 6px;
      color: rgba(255,255,255,.90);
      font-weight: 700;
    }

    .lumlum-orderfill__sum-val--neg { color: rgba(255,255,255,.86); }
    .lumlum-orderfill__sum-val--total { font-size: 14px; letter-spacing: .01em; }

    /* Mobile accordion */
    .lumlum-orderfill__mobile-summary { display: none; margin-bottom: 16px; }

    .lumlum-orderfill__accordion-btn {
      width: 100%;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      border: 1px solid rgba(255,255,255,.10);
      background: #0a0a0a;
      border-radius: 16px;
      padding: 14px 14px;
      color: rgba(255,255,255,.92);
      cursor: pointer;
      transition: transform .18s ease, border-color .18s ease;
    }
    .lumlum-orderfill__accordion-btn:hover { transform: translateY(-2px); border-color: rgba(255,255,255,.20); }

    .lumlum-orderfill__accordion-title { font-size: 13px; font-weight: 700; color: rgba(255,255,255,.86); }
    .lumlum-orderfill__accordion-right { display: flex; align-items: center; gap: 10px; flex: 0 0 auto; }
    .lumlum-orderfill__accordion-total { font-size: 13px; color: rgba(255,255,255,.86); white-space: nowrap; }

    .lumlum-orderfill__chev {
      display: inline-block;
      flex: 0 0 auto;
      box-sizing: border-box;
      width: 10px;
      height: 10px;
      border-right: 2px solid rgba(255,255,255,.72);
      border-bottom: 2px solid rgba(255,255,255,.72);
      transform: rotate(45deg);
      transition: transform .16s ease;
