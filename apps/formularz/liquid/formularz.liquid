              </div>
              <div class="lumlum-ty__kv">
                <div>
                  <div class="lumlum-ty__k">Bank</div>
                  <div class="lumlum-ty__v" data-ty-bank>—</div>
                </div>
              </div>
              <div class="lumlum-ty__kv">
                <div>
                  <div class="lumlum-ty__k">Numer konta</div>
                  <div class="lumlum-ty__v" data-ty-account>—</div>
                </div>
                <button class="lumlum-ty__copy" type="button" data-copy="account">Kopiuj</button>
