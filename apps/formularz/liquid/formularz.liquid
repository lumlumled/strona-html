  function showThankYouOverlayEmailOnly(formObj){
    var ty = ensureThankYouOverlay();

    var orderLabel = '#' + state.cleanId;
    var totalValue = state.payload && state.payload.kwota_proponowana_brutto;

    var pm = String(formObj.payment_method || '').toLowerCase().trim();
    if (pm !== 'transfer' && pm !== 'cod') pm = 'transfer';

    ty.orderEl.textContent = orderLabel;
    ty.totalEl.textContent = moneyPLN(totalValue);
    ty.paymethodEl.textContent = (pm === 'cod') ? 'Pobranie' : 'Przelew';

    var email = (formObj.email || '').trim();
    if (!email) email = 'podany adres e-mail';

    ty.statusEl.textContent = 'Dane zostały zapisane.';

    if (pm === 'transfer'){
      ty.transferBlock.style.display = '';
      ty.receiverEl.textContent = BANK.receiver;
      ty.bankEl.textContent = BANK.name;
      ty.accountEl.textContent = BANK.account;
      ty.amountEl.textContent = moneyPLN(totalValue);
      ty.titleEl.textContent = 'Zamówienie ' + orderLabel;
      ty.copyMap.account = BANK.account.replace(/\s+/g,'');

      ty.hintEl.textContent =
        'Na podany adres e-mail ('+email+') wysłaliśmy wiadomość z dalszymi krokami oraz fakturą proforma. ' +
        'Na twojego maila wysłaliśmy link do szybkich płatności InFact. Jeśli chcesz wygodnie zapłacić Blikiem lub przelewem, wejdź na maila i kliknij w link. ' +
        'Po opłaceniu zamówienia przygotujemy wysyłkę. Jeśli nie widzisz wiadomości, sprawdź folder spam.';
    } else {
      ty.transferBlock.style.display = 'none';
      ty.hintEl.textContent =
        'Na podany adres e-mail ('+email+') wysłaliśmy wiadomość z dalszymi krokami oraz fakturą proforma. ' +
        'Po przygotowaniu zamówienia prześlemy szczegóły wysyłki. Jeśli nie widzisz wiadomości, sprawdź folder spam.';
    }

    ty.wrap.classList.add('is-open');
  }

  /* =========================================================
     InPost GeoWidget selection handler (global callback)
     ========================================================= */
  function extractLockerData(p){
    if (!p) return { id: '', address: '', legacy: '' };

    var id =
      (p.name && String(p.name)) ||
      (p.id && String(p.id)) ||
      (p.pointName && String(p.pointName)) ||
      (p.pointId && String(p.pointId)) ||
      '';

    var street = '';
    var city = '';
    var postcode = '';

    if (p.address && typeof p.address === 'object'){
      street = p.address.line1 || p.address.street || p.address.streetName || '';
      city = p.address.city || '';
      postcode = p.address.postCode || p.address.postcode || '';
    }

    var flatAddress =
      (p.addressDetails && String(p.addressDetails)) ||
      (p.locationDescription && String(p.locationDescription)) ||
      (p.location && String(p.location)) ||
      '';

    var address = '';
    if (street || city || postcode){
      address = [street, (postcode || city) ? ((postcode ? (postcode + ' ') : '') + (city || '')) : '']
        .filter(Boolean).join(', ');
    } else if (flatAddress){
      address = flatAddress;
    } else if (p.address && typeof p.address === 'string'){
      address = p.address;
    }

    address = String(address || '').trim();
    var legacy = (id && address) ? (id + ' — ' + address) : (id || address || '');

    return {
      id: String(id || '').trim(),
      address: address,
      legacy: String(legacy || '').trim()
    };
  }

  function applyLockerSelection(data){
    var idInput = document.getElementById('lumlum-locker-id');
    var adrInput = document.getElementById('lumlum-locker-adres');
    var legacy  = document.getElementById('lumlum-locker-legacy');

    if (idInput) idInput.value = data.id || '';
    if (adrInput) adrInput.value = data.address || '';
    if (legacy)  legacy.value  = data.legacy || '';

    if (els.lockerValue){
      els.lockerValue.textContent = data.legacy || data.id || '—';
    }

    if (els.lockerPicker) els.lockerPicker.classList.add('is-hidden');
    if (els.lockerSelected) els.lockerSelected.classList.remove('is-hidden');

    var err = els.form ? els.form.querySelector('[data-err-for="punkt_odbioru_ID"]') : null;
    if (err){
      err.classList.remove('is-visible');
      err.textContent = '';
    }

    setTimeout(function(){ window.dispatchEvent(new Event('resize')); }, 200);
  }

  window.lumlumOnPointSelect = function(point){
    try{
      var p = point && point.detail ? point.detail : point;
      var data = extractLockerData(p);
      if (!data.id){
        addAlert('error','Nie udało się odczytać punktu paczkomatu. Wybierz ponownie.');
        return;
      }
      applyLockerSelection(data);
    } catch (e){
      addAlert('error','Wystąpił błąd przy wyborze paczkomatu. Spróbuj ponownie.');
    }
  };

  /* =========================================================
     Toggles + reset paczkomatu
     ========================================================= */
  function resetLockerUI(){
    var idInput = document.getElementById('lumlum-locker-id');
    var adrInput = document.getElementById('lumlum-locker-adres');
    var legacy = document.getElementById('lumlum-locker-legacy');

    if (idInput) idInput.value = '';
    if (adrInput) adrInput.value = '';
    if (legacy) legacy.value = '';

    if (els.lockerSelected) els.lockerSelected.classList.add('is-hidden');
    if (els.lockerPicker) els.lockerPicker.classList.remove('is-hidden');
  }

  function toggleInvoiceCompany(on){
    if (!els.invoiceCompanyWrap) return;
    els.invoiceCompanyWrap.classList.toggle('is-hidden', !on);

    // when hiding company invoice, hide warning
    if (!on) showInvShipWarning(false);
  }

  function toggleInvoicePrivate(on){
    if (!els.invoicePrivateWrap) return;
    els.invoicePrivateWrap.classList.toggle('is-hidden', !on);
  }

  function bindToggles(){
    if (els.accBtn){
      els.accBtn.addEventListener('click', function(){ toggleAccordion(); });
    }

    if (els.lockerChangeBtn){
      els.lockerChangeBtn.addEventListener('click', function(){
        resetLockerUI();
        setTimeout(function(){ window.dispatchEvent(new Event('resize')); }, 200);
      });
    }

    root.addEventListener('change', function(e){
      var t = e.target;
      if (!t) return;

      if (t.name === 'delivery_method'){
        var isLocker = t.value === 'INPOST_LOCKER';
        if (els.lockerWrap){
          els.lockerWrap.classList.toggle('is-hidden', !isLocker);
          if (!isLocker){
            resetLockerUI();
          } else {
            if (els.lockerPicker) els.lockerPicker.classList.remove('is-hidden');
            if (els.lockerSelected) els.lockerSelected.classList.add('is-hidden');
            setTimeout(function(){ window.dispatchEvent(new Event('resize')); }, 200);
          }
        }
      }

      if (t.name === 'invoice_enabled'){
        var invPrivate = els.form.querySelector('[name="invoice_private_different"]');
        if (t.checked && invPrivate && invPrivate.checked){
          invPrivate.checked = false;
          toggleInvoicePrivate(false);
        }
        toggleInvoiceCompany(!!t.checked);
      }

      if (t.name === 'invoice_private_different'){
        var invCompany = els.form.querySelector('[name="invoice_enabled"]');
        if (t.checked && invCompany && invCompany.checked){
          invCompany.checked = false;
          toggleInvoiceCompany(false);
        }
        toggleInvoicePrivate(!!t.checked);
      }

      // NEW: country change → COD rule
      if (t.name === 'ship_country'){
        setCodAvailabilityByCountry();
        setLockerAvailability();
        updateShippingCost();
      }

      // obcy prefiks telefonu → paczkomat znika (InPost wymaga PL numeru)
      if (t.name === 'phone_prefix'){
        setLockerAvailability();
      }
    });

    var invCompanyInit = els.form.querySelector('[name="invoice_enabled"]');
    var invPrivateInit = els.form.querySelector('[name="invoice_private_different"]');
    toggleInvoiceCompany(!!(invCompanyInit && invCompanyInit.checked));
    toggleInvoicePrivate(!!(invPrivateInit && invPrivateInit.checked));
  }

  /* =========================================================
     Submit handler
     ========================================================= */
  function attachSubmit(){
    els.form.addEventListener('submit', async function(e){
      e.preventDefault();
      if (state.locked || !state.canSubmit) return;

      var obj = readForm();
      if (!validate(obj)) return;

      setSubmitEnabled(false);
      setSubmitLoading(true, 'Zapisywanie…');
      if (els.substatus) els.substatus.textContent = '';

      obj.id = state.cleanId;
      if (state.formToken) obj.t = state.formToken;
      obj.form_status = 'SUBMITTED';
      obj.form_submitted_at = new Date().toISOString();

      try{
        var resp = await postForm(obj);
        if (!resp.ok){
          setSubmitEnabled(true);
          setSubmitLoading(false);
          if (resp.status === 409){ renderZlozone(); return; }
          addAlert('error','Nie udało się zapisać.');
          return;
        }

        state.locked = true;
        setSubmitLoading(true, 'Zapisano');
        els.submit.disabled = true;

        if (els.formCard) els.formCard.classList.add('is-hidden');
        showThankYouOverlayEmailOnly(obj);
      }catch(err){
        setSubmitEnabled(true);
        setSubmitLoading(false);
        addAlert('error','Wystąpił błąd połączenia. Spróbuj ponownie.');
      }
    });
  }

  /* =========================================================
     Init
     ========================================================= */
  function init(){
    bindToggles();
    attachSubmit();

    injectRequiredNote();
    initPostcodeFormatting();
    bindPhoneSanitizer();

    // NEW: bind copy+warning + COD on country
    bindInvCompanyCopyAndWarning();
    setCodAvailabilityByCountry();
    setLockerAvailability();

    var id = new URLSearchParams(location.search).get('id');
    if (!id){
      addAlert('error','Brak ID zamówienia.');
      return;
    }

    state.cleanId = normalizeId(id);
    state.formToken = new URLSearchParams(location.search).get('t') || '';
    toggleAccordion(false);
    fetchOrder();
  }

  init();
})();
</script>


