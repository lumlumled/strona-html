  function renderRabat24h(data) {
    // Usuń poprzedni baner jeśli istnieje
    var stary = document.getElementById('lumlum-rabat24h-baner');
    if (stary) stary.remove();

    var kwota = data.rabat24h_kwota ? Number(data.rabat24h_kwota) : 0;
    var waznyStr = data.rabat24h_wazny_do ? String(data.rabat24h_wazny_do).trim() : '';

    if (!kwota || !waznyStr) return;

    // Parsuj datę z formatu DD.MM.YYYY HH:mm
    var czesci = waznyStr.match(/^(\d{2})\.(\d{2})\.(\d{4})\s+(\d{2}):(\d{2})$/);
    if (!czesci) return;
    var dataWaznosci = new Date(
      parseInt(czesci[3]),     // rok
      parseInt(czesci[2]) - 1, // miesiąc (0-indexed)
      parseInt(czesci[1]),     // dzień
      parseInt(czesci[4]),     // godzina
      parseInt(czesci[5])      // minuta
    );

    // Sprawdź czy rabat jeszcze aktywny
    if (dataWaznosci <= new Date()) return;

    var cenaKat = data.kwota_proponowana_brutto ? Number(data.kwota_proponowana_brutto) : 0;
    var cenaPoRabacie = cenaKat - kwota;

    var baner = document.createElement('div');
    baner.id = 'lumlum-rabat24h-baner';
    baner.style.cssText = [
      'border:1px solid rgba(255,255,255,.22)',
      'background:rgba(255,255,255,.05)',
      'border-radius:16px',
      'padding:14px 16px',
      'margin-bottom:18px',
      'display:grid',
      'gap:8px'
    ].join(';');

    var etykieta = document.createElement('div');
    etykieta.style.cssText = 'font-size:11px;font-weight:700;letter-spacing:.06em;color:rgba(255,255,255,.55);text-transform:uppercase;';
    etykieta.textContent = 'Oferta specjalna';

    var waznoscWrap = document.createElement('div');
    waznoscWrap.style.cssText = 'font-size:13px;color:rgba(255,255,255,.72);';
    waznoscWrap.textContent = 'Ważna do: ' + waznyStr;

    var cenyWrap = document.createElement('div');
    cenyWrap.style.cssText = 'display:flex;align-items:baseline;gap:10px;flex-wrap:wrap;margin-top:2px;';

    var cenaStara = document.createElement('span');
    cenaStara.style.cssText = 'font-size:13px;color:rgba(255,255,255,.40);text-decoration:line-through;';
    cenaStara.textContent = moneyPLN(cenaKat);

    var rabatBadge = document.createElement('span');
    rabatBadge.style.cssText = 'font-size:12px;color:rgba(255,255,255,.60);';
    rabatBadge.textContent = '-' + moneyPLN(kwota);

    var cenaNowa = document.createElement('span');
    cenaNowa.style.cssText = 'font-size:16px;font-weight:800;color:rgba(255,255,255,.95);';
    cenaNowa.textContent = moneyPLN(cenaPoRabacie);

    cenyWrap.appendChild(cenaStara);
    cenyWrap.appendChild(rabatBadge);
    cenyWrap.appendChild(cenaNowa);

    baner.appendChild(etykieta);
    baner.appendChild(waznoscWrap);
    baner.appendChild(cenyWrap);

    // Wstaw przed kartą formularza
    var formCard = root.querySelector('[data-form-card]');
    if (formCard && formCard.parentNode) {
      formCard.parentNode.insertBefore(baner, formCard);
    }
  }
