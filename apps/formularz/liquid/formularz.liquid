    <label class="lumlum-orderfill__label" for="lumlum-email">
      Email <span class="lumlum-orderfill__req" aria-hidden="true">*</span>
    </label>
<input
  class="lumlum-orderfill__input"
  id="lumlum-email"
  name="email"
  type="email"
  autocomplete="email"
  inputmode="email"
  placeholder="np. kontakt@lumlum.co"
/>
    <div class="lumlum-orderfill__field-error" data-err-for="email"></div>
  </div>

                  <!-- Telefon: prefix + numer (osobne parametry) -->
