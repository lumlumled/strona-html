    }
    .lumlum-paragraph {
      font-size: 2.25rem;
      font-weight: 300;
      margin-top: 0;
      margin-bottom: 1em;
      line-height: 1.47;
      letter-spacing: -0.022em;
    }

    @media screen and (max-width: 1068px) {
      .lumlum-title-main { font-size: 4rem; margin-bottom: 0.85em; line-height: 1.10; letter-spacing: -0.003em; }
      .lumlum-title-sub  { font-size: 2rem; margin-bottom: 0.75em; line-height: 1.10; letter-spacing: 0em; }
      .lumlum-paragraph  { font-size: 1.75rem; margin-bottom: 0.95em; line-height: 1.47; letter-spacing: -0.022em; }
    }
    @media screen and (max-width: 834px) {
      .lumlum-title-main { font-size: 3.5rem; margin-bottom: 0.8em; line-height: 1.115; letter-spacing: 0em; }
      .lumlum-title-sub  { font-size: 1.75rem; margin-bottom: 0.7em; line-height: 1.12; letter-spacing: 0em; }
      .lumlum-paragraph  { font-size: 1.7rem; margin-bottom: 0.9em; line-height: 1.47; letter-spacing: -0.022em; }
    }
    @media screen and (max-width: 430px) {
      .lumlum-title-main { font-size: 2.75rem; margin-bottom: 0.7em; line-height: 1.125; letter-spacing: 0.004em; }
      .lumlum-title-sub  { font-size: 1.5rem; margin-bottom: 0.6em; line-height: 1.125; letter-spacing: 0.004em; }
      .lumlum-paragraph  { font-size: 1.25rem; margin-bottom: 0.85em; line-height: 1.47; letter-spacing: -0.022em; }
    }
    @media screen and (max-width: 375px) {
      .lumlum-title-main { font-size: 2.5rem; margin-bottom: 0.65em; line-height: 1.14; letter-spacing: 0.004em; }
      .lumlum-title-sub  { font-size: 1.375rem; margin-bottom: 0.55em; line-height: 1.14; letter-spacing: 0.004em; }
      .lumlum-paragraph  { font-size: 0.875rem; margin-bottom: 0.8em; line-height: 1.43; letter-spacing: -0.016em; }
    }

    /* ===== LumLum Order Fill (no globals) ===== */
    .lumlum-orderfill {
      background: #000;
      color: rgba(255,255,255,.92);
      min-height: 100vh;
      scroll-margin-top: 120px;
    }

    .lumlum-orderfill__wrap {
      width: 100%;
      margin-top: 8rem;
    }

    .lumlum-orderfill__alerts {
      width: min(1200px, 92%);
      margin: 0 auto;
      padding: 16px 0 0;
    }

    .lumlum-orderfill__alert {
      border: 1px solid rgba(255,255,255,.12);
      background: rgba(255,255,255,.06);
      border-radius: 14px;
      padding: 12px 14px;
      margin-bottom: 10px;
      display: flex;
      align-items: flex-start;
      gap: 10px;
    }
    .lumlum-orderfill__alert.is-error { border-color: rgba(255,255,255,.14); background: rgba(255,255,255,.05); }
    .lumlum-orderfill__alert.is-success { border-color: rgba(255,255,255,.18); background: rgba(255,255,255,.07); }

    .lumlum-orderfill__container {
      width: min(1200px, 92%);
      margin: 0 auto;
      padding: 22px 0 60px;
    }

    .lumlum-orderfill__grid {
      display: grid;
      grid-template-columns: 1fr 420px;
      gap: 24px;
      align-items: start;
    }

    .lumlum-orderfill__col--right {
      position: sticky;
      top: 24px;
      align-self: start;
    }

    .lumlum-orderfill__form-card,
    .lumlum-orderfill__summary-card {
      border: 1px solid rgba(255,255,255,.10);
      background: #0a0a0a;
      border-radius: 16px;
      box-shadow: 0 10px 30px rgba(0,0,0,.45);
      overflow: hidden;
    }

    .lumlum-orderfill__form-card {
      padding: 20px;
      transition: transform .18s ease, border-color .18s ease;
    }
    .lumlum-orderfill__form-card:hover {
      transform: translateY(-2px);
      border-color: rgba(255,255,255,.20);
    }

    .lumlum-orderfill__section-head {
      padding-bottom: 14px;
      border-bottom: 1px solid rgba(255,255,255,.08);
      margin-bottom: 16px;
    }
    .lumlum-orderfill__hint { margin-top: 6px; font-size: 13px; color: rgba(255,255,255,.72); }

    .lumlum-orderfill__block {
      padding: 16px 0;
      border-bottom: 1px solid rgba(255,255,255,.08);
    }
    .lumlum-orderfill__block:last-of-type { border-bottom: 0; }

    .lumlum-orderfill__block-title {
      font-size: 14px;
      font-weight: 600;
      letter-spacing: .02em;
      color: rgba(255,255,255,.86);
      margin-bottom: 12px;
    }

    .lumlum-orderfill__row {
      display: grid;
      gap: 14px;
      margin-bottom: 12px;
    }
    .lumlum-orderfill__row--2 { grid-template-columns: 1fr 1fr; }
    .lumlum-orderfill__row--3 { grid-template-columns: 1fr 1fr 1fr; }
    .lumlum-orderfill__row--address { grid-template-columns: 1.6fr .6fr .6fr; align-items: end; }

    .lumlum-orderfill__label {
      display: block;
      font-size: 12px;
      color: rgba(255,255,255,.76);
      margin-bottom: 1rem;
      margin-top: 1rem;
    }
    .lumlum-orderfill__req { color: rgba(255,255,255,.86); }

    .lumlum-orderfill__input {
      width: 100%;
      background: rgba(255,255,255,.04);
      border: 1px solid rgba(255,255,255,.12);
      border-radius: 14px;
      padding: 12px 12px;
      color: rgba(255,255,255,.92);
      outline: none;
      transition: border-color .16s ease, background .16s ease;
      font-size: 14px;
      line-height: 1.2;
      box-sizing: border-box;
    }
    .lumlum-orderfill__input::placeholder { color: rgba(255,255,255,.38); }
    .lumlum-orderfill__input:focus { border-color: rgba(255,255,255,.28); background: rgba(255,255,255,.06); }

    .lumlum-orderfill__select {
      appearance: none;
      background-image:
        linear-gradient(45deg, transparent 50%, rgba(255,255,255,.55) 50%),
        linear-gradient(135deg, rgba(255,255,255,.55) 50%, transparent 50%);
      background-position:
        calc(100% - 18px) calc(50% - 2px),
        calc(100% - 12px) calc(50% - 2px);
      background-size: 6px 6px, 6px 6px;
      background-repeat: no-repeat;
      padding-right: 34px;
    }

    .lumlum-orderfill__field-error {
      min-height: 16px;
      font-size: 12px;
      color: rgba(255,255,255,.72);
      margin-top: 6px;
    }
    .lumlum-orderfill__field-error.is-visible { color: rgba(255,255,255,.86); }

    .lumlum-orderfill__choice { display: grid; gap: 10px; margin: 6px 0 0; }

    .lumlum-orderfill__radio {
      display: flex;
      align-items: center;
      gap: 10px;
      border: 1px solid rgba(255,255,255,.10);
      background: rgba(255,255,255,.03);
      border-radius: 14px;
      padding: 12px 12px;
      cursor: pointer;
      transition: border-color .16s ease, transform .16s ease, background .16s ease;
      position: relative;
    }
    .lumlum-orderfill__radio:hover { transform: translateY(-2px); border-color: rgba(255,255,255,.20); background: rgba(255,255,255,.04); }
    .lumlum-orderfill__radio input { position: absolute; opacity: 0; pointer-events: none; }
    .lumlum-orderfill__radio-ui {
      width: 16px; height: 16px; border-radius: 999px;
      border: 1px solid rgba(255,255,255,.28);
      background: rgba(0,0,0,.25);
      display: inline-flex; align-items: center; justify-content: center;
      flex: 0 0 auto;
    }
    .lumlum-orderfill__radio-ui::after {
      content: "";
      width: 8px; height: 8px; border-radius: 999px;
      background: rgba(255,255,255,.92);
      transform: scale(0);
      transition: transform .14s ease;
    }
    .lumlum-orderfill__radio input:checked + .lumlum-orderfill__radio-ui::after { transform: scale(1); }
    .lumlum-orderfill__radio-text { color: rgba(255,255,255,.86); font-size: 14px; }

    .lumlum-orderfill__check {
      display: flex;
      align-items: center;
      gap: 10px;
      border: 1px solid rgba(255,255,255,.10);
      background: rgba(255,255,255,.03);
      border-radius: 14px;
      padding: 12px 12px;
      cursor: pointer;
      width: fit-content;
      transition: border-color .16s ease, transform .16s ease, background .16s ease;
      position: relative;
    }
    .lumlum-orderfill__check:hover { transform: translateY(-2px); border-color: rgba(255,255,255,.20); background: rgba(255,255,255,.04); }
    .lumlum-orderfill__check input { position: absolute; opacity: 0; pointer-events: none; }

    .lumlum-orderfill__check-ui {
      width: 16px; height: 16px; border-radius: 6px;
      border: 1px solid rgba(255,255,255,.28);
      background: rgba(0,0,0,.25);
      display: inline-flex; align-items: center; justify-content: center;
      flex: 0 0 auto;
    }
    .lumlum-orderfill__check-ui::after {
      content: "";
      width: 10px; height: 10px; border-radius: 4px;
      background: rgba(255,255,255,.92);
      transform: scale(0);
      transition: transform .14s ease;
    }
    .lumlum-orderfill__check input:checked + .lumlum-orderfill__check-ui::after { transform: scale(1); }
    .lumlum-orderfill__check-text { color: rgba(255,255,255,.86); font-size: 14px; }

    .lumlum-orderfill__micro { font-size: 12px; color: rgba(255,255,255,.62); margin-top: 8px; }

    .lumlum-orderfill__actions { padding-top: 16px; display: grid; gap: 10px; }

    .lumlum-orderfill__cta {
      width: 100%;
      border: 1px solid rgba(255,255,255,.10);
      background: rgba(255,255,255,.92);
      color: rgba(0,0,0,.92);
      border-radius: 16px;
      padding: 14px 14px;
      font-size: 14px;
      font-weight: 700;
      letter-spacing: .02em;
      cursor: pointer;
      transition: transform .18s ease, filter .18s ease, opacity .18s ease;
    }
    .lumlum-orderfill__cta:hover { transform: translateY(-2px); filter: brightness(0.96); }
    .lumlum-orderfill__cta:disabled { opacity: .55; cursor: not-allowed; transform: none; }

    .lumlum-orderfill__substatus { min-height: 16px; font-size: 12px; color: rgba(255,255,255,.72); }

    /* Summary */
    .lumlum-orderfill__summary-card--desktop {
      padding: 18px;
      transition: transform .18s ease, border-color .18s ease;
    }
    .lumlum-orderfill__summary-card--desktop:hover { transform: translateY(-2px); border-color: rgba(255,255,255,.20); }

    .lumlum-orderfill__summary-card--mobile {
      padding: 14px;
      border-radius: 14px;
      box-shadow: none;
      margin-top: 12px;
    }

    .lumlum-orderfill__summary-title { font-size: 14px; font-weight: 700; color: rgba(255,255,255,.86); margin-bottom: 12px; }

    .lumlum-orderfill__products {
      display: grid;
      gap: 12px;
      padding-bottom: 14px;
      border-bottom: 1px solid rgba(255,255,255,.08);
    }

    .lumlum-orderfill__product {
      display: grid;
      grid-template-columns: 54px 1fr auto;
      gap: 12px;
      align-items: center;
    }

    .lumlum-orderfill__thumb {
      width: 54px;
      height: 54px;
      border-radius: 14px;
      overflow: hidden;
      border: 1px solid rgba(255,255,255,.10);
      background: rgba(255,255,255,.03);
      flex: 0 0 auto;
    }
    .lumlum-orderfill__thumb-img { width: 100%; height: 100%; object-fit: cover; display: block; }

    .lumlum-orderfill__pname { font-size: 13px; color: rgba(255,255,255,.88); line-height: 1.3; }
    .lumlum-orderfill__pqty { margin-top: 4px; font-size: 12px; color: rgba(255,255,255,.62); }

    .lumlum-orderfill__pline { font-size: 13px; color: rgba(255,255,255,.80); padding-left: 10px; white-space: nowrap; }
    .lumlum-orderfill__sum { padding-top: 14px; display: grid; gap: 8px; }

    .lumlum-orderfill__sum-row {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      font-size: 13px;
      color: rgba(255,255,255,.78);
    }

    .lumlum-orderfill__sum-row--total {
      padding-top: 10px;
