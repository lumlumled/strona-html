  function parseMoney(val){
    if (val == null) return NaN;
    var s = String(val).trim();
    if (!s) return NaN;
    s = s.replace(/[^\d\-,.]/g, '').replace(/\s/g,'');
    var hasDot = s.indexOf('.') !== -1;
    var hasComma = s.indexOf(',') !== -1;
    if (hasDot && hasComma){
      s = s.replace(/\./g,'').replace(',', '.');
    } else {
      s = s.replace(',', '.');
    }
    var n = Number(s);
    return isFinite(n) ? n : NaN;
  }

  function moneyPLN(v){
    var n = parseMoney(v);
    if (!isFinite(n)) return '—';
    return new Intl.NumberFormat('pl-PL',{style:'currency',currency:'PLN'}).format(n);
  }

  function normalizeId(raw){
    if (raw == null) return '';
    var s = String(raw).trim();
    s = s.replace(/^#/, '');
    return s;
  }

  function isBlank(v){ return !v || String(v).trim() === ''; }

  function normalizeEmail(email){
    return String(email || '').trim().toLowerCase();
  }

  function isValidEmail(email){
    var e = normalizeEmail(email);
    return /^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/.test(e);
  }

  function normalizePhoneNumber(raw){
    return String(raw || '').replace(/\D/g, '');
  }

  function getExpectedPhoneLength(prefix){
    var map = {
      '+48': 9,
      '+49': [10,11,12],
      '+420': 9,
      '+421': 9,
      '+43': [10,11,12,13],
      '+31': 9,
      '+32': 9,
      '+33': 9,
      '+46': [7,8,9],
      '+47': 8,
      '+45': 8,
      '+358': [9,10,11,12],
      '+353': [9,10],
      '+39': [9,10,11],
      '+34': 9,
      '+351': 9,
      '+41': 9,
      '+44': [10,11],
      '+1': 10
    };
    return map[prefix] || { min: 6, max: 15 };
  }

  function isValidPhone(prefix, raw){
    var digits = normalizePhoneNumber(raw);
    var rule = getExpectedPhoneLength(prefix);

    if (!digits) return false;

    if (Array.isArray(rule)) {
      return rule.indexOf(digits.length) !== -1;
    }

    if (typeof rule === 'number') {
      return digits.length === rule;
    }

    if (typeof rule === 'object' && rule.min && rule.max) {
      return digits.length >= rule.min && digits.length <= rule.max;
    }

    return digits.length >= 6 && digits.length <= 15;
  }

