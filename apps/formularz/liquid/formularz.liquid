  <style>
    /* LumLum – typografia bez globali, zgodna z base.css */
    .lumlum-title-main {
      font-size: 4.5rem;
      font-weight: 500;
      margin-top: 0;
      margin-bottom: 0.9em;
      line-height: 1.083;
      letter-spacing: -0.003em;
    }
    .lumlum-title-sub {
      font-size: 2.5rem;
      font-weight: 400;
      margin-top: 0;
      margin-bottom: 0.8em;
      line-height: 1.10;
