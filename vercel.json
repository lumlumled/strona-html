{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/index.js": {
      "includeFiles": "{apps/hub/app.html,apps/hub/pozwolenia.html,apps/hub/wkrotce.html,apps/hub/assets/**,apps/shared/**}",
      "maxDuration": 30
    },
    "api/backlog-b2c.js": {
      "includeFiles": "{apps/backlog-b2c/app.html,apps/backlog-b2c/assets/**,apps/shared/**}",
      "maxDuration": 180
    },
    "api/crm.js": {
      "includeFiles": "{apps/crm/app.html,apps/crm/assets/**,apps/shared/**}",
      "maxDuration": 180
    },
    "api/komunikator.js": {
      "includeFiles": "{apps/komunikator/app.html,apps/komunikator/assets/**,apps/shared/**}",
      "maxDuration": 180
    },
    "api/wiedza.js": {
      "includeFiles": "{apps/wiedza/app.html,apps/hub/assets/**,apps/shared/**}",
      "maxDuration": 60
    },
    "api/sprzedaze.js": {
      "includeFiles": "{apps/sprzedaze/app.html,apps/sprzedaze/assets/**,apps/shared/**}",
      "maxDuration": 180
    },
    "api/fulfillment.js": {
      "includeFiles": "{apps/fulfillment/app.html,apps/fulfillment/assets/**,apps/shared/**}",
      "maxDuration": 180
    },
    "api/wyceny.js": {
      "includeFiles": "{apps/wyceny/app.html,apps/wyceny/szybka.html,apps/wyceny/assets/**,apps/shared/**}",
      "maxDuration": 180
    },
    "api/formularz.js": {
      "includeFiles": "{apps/formularz/**,apps/shared/**}",
      "maxDuration": 180
    }
  },
  "crons": [
    { "path": "/backlog-b2c/api/cron/umowa-draft", "schedule": "0 5 * * 1-5" },
    { "path": "/backlog-b2c/api/cron/log-polaczen-closeout", "schedule": "0 20 * * 1-5" },
    { "path": "/backlog-b2c/api/cron/podsumowanie-dnia", "schedule": "0 21 * * 1-5" },
    { "path": "/wiadomosci/api/cron/worker", "schedule": "15 7 * * *" }
  ],
  "redirects": [
    { "source": "/backlog-b2c", "destination": "/backlog-b2c/", "permanent": false },
    { "source": "/crm", "destination": "/crm/", "permanent": false },
    { "source": "/sprzedaze", "destination": "/sprzedaze/", "permanent": false },
    { "source": "/fulfillment", "destination": "/fulfillment/", "permanent": false },
    { "source": "/wyceny", "destination": "/wyceny/", "permanent": false },
    { "source": "/szybka-wycena", "destination": "/wyceny/szybka-wycena", "permanent": false },
    { "source": "/szybka", "destination": "/wyceny/szybka-wycena", "permanent": false },
    { "source": "/wiadomosci", "destination": "/wiadomosci/", "permanent": false },
    { "source": "/wiedza", "destination": "/wiedza/", "permanent": false }
  ],
  "rewrites": [
    { "source": "/backlog-b2c/", "destination": "/api/backlog-b2c" },
    { "source": "/backlog-b2c/:path*", "destination": "/api/backlog-b2c" },
    { "source": "/crm/", "destination": "/api/crm" },
    { "source": "/crm/:path*", "destination": "/api/crm" },
    { "source": "/sprzedaze/", "destination": "/api/sprzedaze" },
    { "source": "/sprzedaze/:path*", "destination": "/api/sprzedaze" },
    { "source": "/fulfillment/", "destination": "/api/fulfillment" },
    { "source": "/fulfillment/:path*", "destination": "/api/fulfillment" },
    { "source": "/wyceny/", "destination": "/api/wyceny" },
    { "source": "/wyceny/:path*", "destination": "/api/wyceny" },
    { "source": "/formularz/:path*", "destination": "/api/formularz" },
    { "source": "/wiadomosci/", "destination": "/api/komunikator" },
    { "source": "/wiadomosci/:path*", "destination": "/api/komunikator" },
    { "source": "/wiedza/", "destination": "/api/wiedza" },
    { "source": "/wiedza/:path*", "destination": "/api/wiedza" },
    { "source": "/", "destination": "/api/index" },
    { "source": "/sw.js", "destination": "/api/index" },
    { "source": "/login", "destination": "/api/index" },
    { "source": "/logout", "destination": "/api/index" },
    { "source": "/pozwolenia", "destination": "/api/index" },
    { "source": "/wiadomosci", "destination": "/api/index" },
    { "source": "/statystyki", "destination": "/api/index" },
    { "source": "/assets/:path*", "destination": "/api/index" },
    { "source": "/shared/:path*", "destination": "/api/index" },
    { "source": "/api/:path*", "destination": "/api/index" }
  ]
}
